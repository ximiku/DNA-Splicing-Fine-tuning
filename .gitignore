__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Raw reference inputs are too large for ordinary Git.
data/raw/*
!data/raw/GRCh38.p14.genome.fa.fai

# Keep lightweight processed metadata/parquet files, but exclude full Arrow
# shards and caches from the full dataset.
data/processed/dnabert2_splice_401/**/*.arrow
data/processed/dnabert2_splice_401/**/cache-*.arrow
data/processed/dnabert2_splice_401/train.parquet
data/processed/**/*.arrow
data/processed/**/cache-*.arrow
data/processed/**/train.parquet

# Keep metrics, trainer state, tokenizer/config files, and prediction parquet.
# Exclude model weights and optimizer states because this repository uses
# ordinary Git only, not Git LFS.
outputs/**/*.safetensors
outputs/**/optimizer.pt
outputs/**/checkpoints/checkpoint-*/
*.ckpt
/checkpoint-*/

.env
.venv/
venv/
